// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String        @id @default(uuid())
  name              String        @unique
  type              String        @default("CASH")
  currency          String        @default("USD")
  isArchived        Boolean       @default(false) @map("is_archived")
  createdAt         DateTime      @default(now()) @map("created_at")
  transactions      Transaction[] @relation("TransferOrigin")
  receivedTransfers Transaction[] @relation("TransferDestination")

  @@map("accounts")
}

model Category {
  id            String          @id @default(uuid())
  name          String          @unique
  type          String // 'INCOME', 'EXPENSE', 'TRANSFER'
  budgetUsd     Int?            @map("budget_usd")
  subcategories Subcategory[]
  transactions  Transaction[]
  monthlyBudgets MonthlyBudget[]

  @@map("categories")
}

model Subcategory {
  id           String        @id @default(uuid())
  categoryId   String        @map("category_id")
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  transactions Transaction[]

  @@unique([categoryId, name])
  @@map("subcategories")
}

model Transaction {
  id              String       @id @default(uuid())
  provider        String       @default("MANUAL")
  providerTransactionId String? @map("provider_transaction_id")
  transactionDate DateTime     @map("transaction_date")
  accountId       String       @map("account_id")
  account         Account      @relation("TransferOrigin", fields: [accountId], references: [id])
  categoryId      String       @map("category_id")
  category        Category     @relation(fields: [categoryId], references: [id])
  subcategoryId   String?      @map("subcategory_id")
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])
  transactionType String       @map("transaction_type") // 'INCOME', 'EXPENSE', 'TRANSFER'
  amount          Int
  currency        String
  baseAmountUsd   Int          @map("base_amount_usd")
  note            String?
  description     String?
  createdAt       DateTime     @default(now()) @map("created_at")
  destinationAccountId String?  @map("destination_account_id")
  destinationAccount   Account? @relation("TransferDestination", fields: [destinationAccountId], references: [id])
  isOpeningBalance     Boolean  @default(false) @map("is_opening_balance")
  excludeFromTotals    Boolean  @default(false) @map("exclude_from_totals")

  @@unique([provider, providerTransactionId])
  @@map("transactions")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // 'CREATE' | 'UPDATE' | 'DELETE' | 'IMPORT'
  entityType String   // 'ACCOUNT' | 'CATEGORY' | 'SUBCATEGORY' | 'TRANSACTION' | 'SYSTEM'
  entityId   String?  // ID de la entidad (puede ser null en eventos de SYSTEM)
  entityName String?  // Nombre legible en el momento de la acción
  details    String?  // JSON serializado con contexto adicional (montos, campos cambiados, etc.)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

model ExchangeRate {
  id           String  @id
  rateDate     String  @map("rate_date")
  fetchedAt    Int     @map("fetched_at")
  usdOficial   Float   @map("usd_oficial")
  usdParalelo  Float?  @map("usd_paralelo")
  eurOficial   Float   @map("eur_oficial")
  eurParalelo  Float?  @map("eur_paralelo")
  source       String

  @@map("exchange_rates")
}

model MonthlyBudget {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  yearMonth  String   @map("year_month") // Formato: "YYYY-MM"
  budgetUsd  Int      @map("budget_usd") // En centavos
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([categoryId, yearMonth])
  @@map("monthly_budgets")
}
